  },
  "quality": [
    {
      "label": "Recall @ 1",
      "value": "0.33",
      "target": "tgt 0.50",
      "tone": "warn"
    },
    {
      "label": "Recall @ 10",
      "value": "0.56",
      "target": "tgt 0.85",
      "tone": "warn"
