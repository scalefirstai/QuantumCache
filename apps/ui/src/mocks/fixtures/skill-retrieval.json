        "name": "doc_hash",
        "description": "sha256 of source document"
      },
      {
        "name": "span_hash",
        "description": "sha256 of the span itself"
      },
      {
        "name": "text",
        "description": "verbatim span content"
      },
      {
        "name": "anchor",
        "description": "PageAnchor or SectionAnchor for citation"
      },
      {
        "name": "score",
        "description": "RRF score \u00b7 post-fusion"
      },
      {
        "name": "source",
        "description": "one of: edgar (4596), bny-ir (3842), afme (3155), nist_800_53 (1196), caiq (261), nist_csf (219), ccm (197)"
      }
    ]
  },
  "latency": {
