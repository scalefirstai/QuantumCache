        "label": "BM25 lexical",
        "ms": 340,
        "tone": "step"
      },
      {
        "label": "Dense retrieval",
        "ms": 280,
        "tone": "step"
      },
      {
        "label": "RRF fusion",
        "ms": 20,
        "tone": "filter"
      },
      {
        "label": "Halt + slice",
        "ms": 10,
        "tone": "filter"
      },
      {
        "label": "Total uncached",
        "ms": 650,
        "tone": "total"
      },
      {
        "label": "Total target",
        "ms": 1200,
        "tone": "cached"
      }
