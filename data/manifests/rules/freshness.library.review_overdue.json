{
  "rule_id": "freshness.library.review_overdue",
  "engine": "freshness",
  "title": "Library entry overdue for review",
  "description": "Flags a library entry when its `review_due` date has passed. Review cadence is governed by SME ownership policy.",
  "priority": 20,
  "status": "active",
  "version": "1.0.0",
  "when": {
    "all": [
      {
        "field": "library_entry.review_due",
        "op": "exists"
      },
      {
        "field": "library_entry.review_due",
        "op": "age_days_gt",
        "value": 0
      }
    ]
  },
  "then": {
    "stale": true,
    "reason": "library entry overdue for review since {library_entry.review_due}",
    "tags": [
      "library",
      "review"
    ]
  },
  "review_queue": "ops",
  "tags": [
    "bootstrap",
    "library"
  ],
  "created_at": "2026-05-12T09:02:12.352999+00:00",
  "updated_at": "2026-05-12T09:02:12.353007+00:00",
  "approved_at": null,
  "approved_by": null,
  "submitted_by": null,
  "rationale": null
}