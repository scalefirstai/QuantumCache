  {
    "rule_id": "approval.halt.validate",
    "engine": "approval",
    "title": "Validator halt \u2192 legal review",
    "description": "Validate-verdict = halt means a citation/freshness/scrub guardrail tripped. Route to legal queue for review.",
    "priority": 20,
    "status": "active",
    "version": "1.0.0",
    "when": {
      "field": "validate_verdict",
      "op": "eq",
      "value": "halt"
    },
    "then": {
      "route": "halt",
      "queue": "legal",
      "rationale": "Validator halted (citation/freshness/scrub guardrail) \u2014 legal review."
    },
    "review_queue": "legal",
    "tags": [
      "bootstrap",
      "halt"
    ],
