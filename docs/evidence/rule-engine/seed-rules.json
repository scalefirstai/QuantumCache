  {
    "rule_id": "approval.sme.low_confidence",
    "engine": "approval",
    "title": "Low classify confidence \u2192 SME queue",
    "description": "QuestionMapper confidence below 0.70 means the canonical mapping is uncertain. SME must verify before answer is shipped.",
    "priority": 50,
    "status": "active",
    "version": "1.0.0",
    "when": {
      "field": "classify_confidence",
      "op": "lt",
      "value": 0.7
    },
    "then": {
      "route": "sme_queue",
      "rationale": "Classify confidence below 0.70 SME threshold \u2014 SME confirmation required."
    },
    "review_queue": "ops",
    "tags": [
