  {
    "rule_id": "approval.halt.pii",
    "engine": "approval",
    "title": "PII halt \u2192 legal review",
    "description": "Any PII halt-severity finding requires legal review before any further action. Mirrors PiiScrubber.halt = True case.",
    "priority": 10,
    "status": "active",
    "version": "1.0.0",
    "when": {
      "field": "pii_halt",
      "op": "truthy"
    },
    "then": {
      "route": "halt",
      "queue": "legal",
      "rationale": "PiiScrubber raised halt \u2014 confidentiality risk; legal must review before any further action."
    },
    "review_queue": "legal",
    "tags": [
      "bootstrap",
      "halt"
    ],
