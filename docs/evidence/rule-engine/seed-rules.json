  {
    "rule_id": "freshness.evidence.pillar3.age_12mo",
    "engine": "freshness",
    "title": "Pillar 3 evidence older than 12 months",
    "description": "Quarterly Pillar 3 disclosures rotate every quarter; anything older than 12 months is considered stale for client-facing answers.",
    "priority": 40,
    "status": "active",
    "version": "1.0.0",
    "when": {
      "any": [
        {
          "field": "evidence_oldest.pillar3_date",
          "op": "exists",
          "value": null
        }
      ]
    },
    "then": {
      "stale": true,
      "reason": "pillar3 evidence older than 12 months: {evidence_oldest.pillar3_date}",
      "tags": [
        "evidence",
        "pillar3"
      ]
    },
    "review_queue": "ops",
    "tags": [
      "bootstrap",
      "evidence"
    ],
